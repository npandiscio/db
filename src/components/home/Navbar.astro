---
import Container from '../shared/Container.astro';
import Icon from '../shared/Icon.astro';

const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<header class="fixed top-0 w-full z-50 bg-white/90 dark:bg-background-dark/90 backdrop-blur-md border-b border-slate-100 dark:border-slate-800">
  <Container class="h-20 flex items-center justify-between">
    <!-- Logo -->
    <a href={base} class="flex items-center gap-3 group cursor-pointer">
      <div class="text-primary">
        <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 48 48">
          <path d="M24 0.757355L47.2426 24L24 47.2426L0.757355 24L24 0.757355ZM21 35.7574V12.2426L9.24264 24L21 35.7574Z" />
        </svg>
      </div>
      <h1 class="text-xl font-black tracking-tighter uppercase">Architects</h1>
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden md:flex items-center gap-10">
      <a 
        href={base} 
        class:list={[
          "text-sm font-semibold transition-colors",
          currentPath === '/' 
            ? "text-primary" 
            : "text-slate-600 dark:text-slate-400 hover:text-primary dark:hover:text-primary"
        ]}
      >
        Home
      </a>
      <a 
        href={`${base}projects`} 
        class:list={[
          "text-sm font-semibold transition-colors",
          currentPath === '/projects' || currentPath.startsWith('/projects/')
            ? "text-primary" 
            : "text-slate-600 dark:text-slate-400 hover:text-primary dark:hover:text-primary"
        ]}
      >
        Projects
      </a>
      <a 
        href={`${base}about`} 
        class:list={[
          "text-sm font-semibold transition-colors",
          currentPath === '/about'
            ? "text-primary" 
            : "text-slate-600 dark:text-slate-400 hover:text-primary dark:hover:text-primary"
        ]}
      >
        About
      </a>
    </nav>

    <!-- CTA -->
    <div class="flex items-center gap-4">
      <a 
        href={`${base}contact`} 
        class="bg-primary hover:bg-primary/90 text-white px-6 py-2.5 rounded text-sm font-bold uppercase tracking-wider transition-all flex items-center gap-2"
      >
        <Icon name="send" size={16} />
        <span>Inquire</span>
      </a>
      
      <!-- Mobile menu button -->
      <button class="md:hidden p-2 text-slate-600 dark:text-slate-400" aria-label="Open menu">
  <Icon name="menu" size={24} />
</button>
    </div>
  </Container>
</header>
