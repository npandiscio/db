---
import Container from '../shared/Container.astro';
import ProjectCard from './ProjectCard.astro';
import Icon from '../shared/Icon.astro';
import project1Image from '../../assets/img/home-page-img-03.jpg';
import project2Image from '../../assets/img/home-page-img-04.jpg';
import project3Image from '../../assets/img/home-page-img-05.jpg';
import project4Image from '../../assets/img/home-page-img-06.jpg';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;

const projects = [
  {
    title: "The Concrete Residence",
    category: "Residential",
    year: "2023",
    image: project1Image,
    alt: "Monochromatic Brutalist concrete building exterior"
  },
  {
    title: "Linear Pavilion",
    category: "Cultural",
    year: "2022",
    image: project2Image,
    alt: "Modern minimal pavilion with vertical wooden slats"
  },
  {
    title: "Urban Loft III",
    category: "Interior",
    year: "2021",
    image: project3Image,
    alt: "Ultra modern open-plan urban loft interior"
  },
  {
    title: "Glass House Extension",
    category: "Residential",
    year: "2023",
    image: project4Image,
    alt: "Contemporary glass and steel house extension"
  }
];
---

<section class="py-24 md:py-32">
  <Container>
    <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
      <div class="max-w-xl">
        <span class="text-primary font-bold uppercase tracking-[0.3em] text-xs mb-4 block">Portfolio</span>
        <h2 class="text-4xl md:text-5xl font-black tracking-tighter uppercase leading-none">Selected Works</h2>
      </div>
      <a href={`${base}projects`} class="group flex items-center gap-2 text-sm font-bold uppercase tracking-widest border-b-2 border-primary pb-1">
        All Projects
        <Icon name="arrow-right" size={16} class="group-hover:translate-x-1 transition-transform" />
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12">
      {projects.map((project, index) => (
        <ProjectCard
          title={project.title}
          category={project.category}
          year={project.year}
          image={project.image}
          alt={project.alt}
          index={index}
        />
      ))}
    </div>
  </Container>
</section>
