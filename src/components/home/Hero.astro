---
import Button from '../shared/Button.astro';
import Icon from '../shared/Icon.astro';
import { Image } from 'astro:assets';
import heroImage from '../../assets/img/home-page-img-01.jpg';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<section class="relative h-screen w-full flex items-center justify-center overflow-hidden pt-20">
  <!-- Background Image with Overlay -->
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 z-10 bg-[linear-gradient(135deg,rgba(7,27,61,0.88),rgba(51,71,91,0.62),rgba(0,116,188,0.24))]" />
    <Image
      src={heroImage}
      alt="Minimalist concrete skyscraper reaching towards a clear sky"
      class="w-full h-full object-cover saturate-[0.85]"
      loading="eager"
      fetchpriority="high"
      widths={[640, 1024, 1280, 1600]}
      sizes="100vw"
      quality={75}
      format="webp"
    />
  </div>

  <!-- Content -->
  <div class="relative z-20 text-center px-6">
    <p class="text-accent text-xs md:text-sm font-bold uppercase tracking-[0.45em] mb-5">
      RF Venue Palette
    </p>
    <h1 class="text-white text-6xl md:text-9xl font-black leading-none tracking-tight mb-6 uppercase">
      Form &<br />Function
    </h1>
    <p class="text-white/90 text-lg md:text-xl font-light max-w-2xl mx-auto mb-10 tracking-wide uppercase">
      Defining modern spaces through precision and soul
    </p>
    <div class="flex flex-col md:flex-row gap-4 justify-center items-center">
      <Button href={`${base}projects`} variant="primary" size="lg">View Portfolio</Button>
      <Button href={`${base}about`} variant="secondary" size="lg">Our Story</Button>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-20 animate-bounce">
    <Icon name="chevron-down" size={32} class="text-accent" />
  </div>
</section>
