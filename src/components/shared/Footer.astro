---
import Container from '../shared/Container.astro';
import Logo from '../shared/Logo.astro';
import Icon from '../shared/Icon.astro';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<footer class="border-t border-primary/15 bg-primary text-white py-12">
  <Container size="xl">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12">
      <div class="col-span-1 md:col-span-2">
        <div class="flex items-center gap-3 text-white mb-6">
          <Logo size="sm" class="text-accent" />
          <span class="font-bold uppercase tracking-tight">Studio Alpha</span>
        </div>
        <p class="text-white/78 text-sm max-w-sm font-light leading-relaxed">
          A global architectural practice focused on sustainable design, innovative urbanism, and the relationship between people and built environments.
        </p>
      </div>
      
      <div>
        {/* FIXED: Changed from h4 to h2 (since no h1/h2/h3 in footer, h2 is appropriate for sections) */}
        <h2 class="text-accent text-xs font-bold uppercase tracking-widest mb-6">Connect</h2>
        <ul class="space-y-3">
          <li>
            <a href="#" class="text-white/78 hover:text-accent transition-colors text-sm font-light flex items-center gap-2">
              <Icon name="brand-instagram" size={16} />
              Instagram
            </a>
          </li>
          <li>
            <a href="#" class="text-white/78 hover:text-accent transition-colors text-sm font-light flex items-center gap-2">
              <Icon name="brand-linkedin" size={16} />
              LinkedIn
            </a>
          </li>
          <li>
            <a href="#" class="text-white/78 hover:text-accent transition-colors text-sm font-light flex items-center gap-2">
              <Icon name="brand-behance" size={16} />
              Behance
            </a>
          </li>
        </ul>
      </div>
      
      <div>
        {/* FIXED: Changed from h4 to h2 (same level as "Connect") */}
        <h2 class="text-accent text-xs font-bold uppercase tracking-widest mb-6">Inquiries</h2>
        <p class="text-white/70 text-sm font-light mb-1">General:</p>
        <p class="text-white text-sm font-medium mb-4 flex items-center gap-2">
          <Icon name="mail" size={16} class="text-accent" />
          hello@studioalpha.com
        </p>
        <p class="text-white/70 text-sm font-light mb-1">Press:</p>
        <p class="text-white text-sm font-medium flex items-center gap-2">
          <Icon name="mail" size={16} class="text-accent" />
          press@studioalpha.com
        </p>
      </div>
    </div>
    
    <div class="mt-16 pt-8 border-t border-white/15 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-white/58 text-[10px] uppercase tracking-widest font-medium">
        © 2024 Studio Alpha Architecture. All Rights Reserved.
      </p>
      <div class="flex gap-8">
        <a href={`${base}privacy`} class="text-white/58 text-[10px] uppercase tracking-widest font-medium hover:text-accent transition-colors">
          Privacy Policy
        </a>
        <a href={`${base}terms`} class="text-white/58 text-[10px] uppercase tracking-widest font-medium hover:text-accent transition-colors">
          Terms
        </a>
      </div>
    </div>
  </Container>
</footer>
