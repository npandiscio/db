---
export interface Props {
  name: string;
  class?: string;
  size?: number;
}

const { name, class: className = '', size = 24 } = Astro.props;

// Dynamic import based on icon name
const icons = {
  mail: (await import('~icons/tabler/mail')).default,
  phone: (await import('~icons/tabler/phone')).default,
  map: (await import('~icons/tabler/map-pin')).default,
  'arrow-right': (await import('~icons/tabler/arrow-right')).default,
  arrowUp: (await import('~icons/tabler/arrow-up')).default,
  arrowDown: (await import('~icons/tabler/arrow-down')).default,
  menu: (await import('~icons/tabler/menu')).default,
  search: (await import('~icons/tabler/search')).default,
  close: (await import('~icons/tabler/x')).default,
  download: (await import('~icons/tabler/download')).default,
  share: (await import('~icons/tabler/share')).default,
  globe: (await import('~icons/tabler/globe')).default,
  architecture: (await import('~icons/tabler/building-arch')).default,
  'building-arch': (await import('~icons/tabler/building-arch')).default,
  heart: (await import('~icons/tabler/heart')).default,
  calendar: (await import('~icons/tabler/calendar')).default,
  location: (await import('~icons/tabler/map-pin')).default,
  send: (await import('~icons/tabler/send')).default,
  check: (await import('~icons/tabler/check')).default,
  chevronDown: (await import('~icons/tabler/chevron-down')).default,
  chevronRight: (await import('~icons/tabler/chevron-right')).default,
  plus: (await import('~icons/tabler/plus')).default,
  minus: (await import('~icons/tabler/minus')).default,
   'arrow-narrow-right': (await import('~icons/tabler/arrow-narrow-right')).default,
  'chevron-down': (await import('~icons/tabler/chevron-down')).default,
  'brand-instagram': (await import('~icons/tabler/brand-instagram')).default,
  'brand-linkedin': (await import('~icons/tabler/brand-linkedin')).default,
  'brand-behance': (await import('~icons/tabler/brand-behance')).default,
  'eye': (await import('~icons/tabler/eye')).default,
  'map-pin': (await import('~icons/tabler/map-pin')).default,
  'copyright': (await import('~icons/tabler/copyright')).default,
  'clock': (await import('~icons/tabler/clock')).default,
  'file-check': (await import('~icons/tabler/file-check')).default,
  'users': (await import('~icons/tabler/users')).default,
  'shield': (await import('~icons/tabler/shield')).default,
  'scale': (await import('~icons/tabler/scale')).default,
  'circle-x': (await import('~icons/tabler/circle-x')).default,
  'shield-lock': (await import('~icons/tabler/shield-lock')).default,
  'file-text': (await import('~icons/tabler/file-text')).default,
  'info-circle': (await import('~icons/tabler/info-circle')).default,
  'database': (await import('~icons/tabler/database')).default,
  'settings': (await import('~icons/tabler/settings')).default,
  'cookie': (await import('~icons/tabler/cookie')).default,
  'list': (await import('~icons/tabler/list')).default,
  'contract': (await import('~icons/tabler/contract')).default,
  'gavel': (await import('~icons/tabler/gavel')).default,
  'message-circle': (await import('~icons/tabler/message-circle')).default,
  'arrow-up': (await import('~icons/tabler/arrow-up')).default,
  'lock': (await import('~icons/tabler/lock')).default,
  'badge': (await import('~icons/tabler/badge')).default,
  'checkmark': (await import('~icons/tabler/check')).default,
  'user-check': (await import('~icons/tabler/user-check')).default,
  'hand-click': (await import('~icons/tabler/hand-click')).default,
} as const;

type IconName = keyof typeof icons;

const IconComponent = icons[name as IconName];

if (!IconComponent) {
  console.warn(`Icon "${name}" not found`);
  return null;
}
---

<IconComponent class={className} width={size} height={size} />
