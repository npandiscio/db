---
import Container from '../shared/Container.astro';
import Icon from '../shared/Icon.astro';
---

<section class="bg-accent text-white py-20">
  <Container>
    <div class="flex flex-col md:flex-row items-center justify-between gap-10">
      <div class="max-w-md">
        <h3 class="text-3xl font-bold mb-4">Subscribe to our monograph.</h3>
        <p class="text-white/72">Quarterly updates on our latest builds, design philosophy, and industry insights.</p>
      </div>
      <div class="flex w-full md:w-auto gap-2">
        <input 
          type="email" 
          placeholder="Email address" 
          class="bg-white/10 border-white/20 text-white rounded px-6 py-4 flex-grow md:w-80 outline-none focus:border-primary transition-all"
        />
        <button class="bg-primary text-white px-8 py-4 rounded font-bold uppercase text-sm tracking-widest hover:bg-[#0095cd] transition-all whitespace-nowrap flex items-center gap-2 group">
          <span>Join</span>
          <Icon name="send" size={16} class="transition-transform group-hover:translate-x-1" />
        </button>
      </div>
    </div>
  </Container>
</section>
