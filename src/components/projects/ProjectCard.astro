---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

export interface Props {
  title: string;
  location: string;
  year: string;
  category: string;
  image: ImageMetadata | string;  // Accept both types
  alt: string;
}

const { title, location, year, category, image, alt } = Astro.props;

// Helper to check if it's an SVG (for local images)
// @ts-ignore - image.format might not be in types yet
const isSVG = typeof image !== 'string' && image?.format === 'svg';

// For remote images, we need to ensure they're from allowed domains
// You can add this check if needed
const isRemoteImage = typeof image === 'string' && (image.startsWith('http') || image.startsWith('https'));
---

<div class="group cursor-pointer">
  <div class="relative overflow-hidden mb-4 bg-slate-200 dark:bg-slate-800 rounded flex items-center justify-center">
    
    {typeof image === 'string' ? (
      // Handle string URLs (could be public folder or remote images)
      isRemoteImage ? (
        // Remote image - use img tag with proper attributes
        <img
          src={image}
          alt={alt}
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
          loading="lazy"
          decoding="async"
          width={800}
          height={600}
        />
      ) : (
        // Public folder image - use img tag with explicit dimensions
        <img
          src={image}
          alt={alt}
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
          loading="lazy"
          decoding="async"
          width={800}
          height={600}
        />
      )
    ) : isSVG ? (
      // Local SVG - use img tag to avoid rasterization
      <img
        src={image.src}
        alt={alt}
        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
        loading="lazy"
        decoding="async"
        width={800}
        height={600}
      />
    ) : (
      <Image
        src={image}
        alt={alt}
       widths={[240, 540, 720, image.width]}
  sizes={`(max-width: 360px) 240px, (max-width: 720px) 540px, (max-width: 1600px) 720px, ${image.width}px`}
  
      />
    )}
    
  </div>
  
  <div class="flex justify-between items-start">
    <div>
      <h3 class="text-slate-900 dark:text-slate-100 text-lg font-semibold tracking-tight">{title}</h3>
      <p class="text-slate-500 dark:text-slate-400 text-sm font-light">{category} • {location}</p>
    </div>
    <span class="text-slate-400 text-sm font-medium">{year}</span>
  </div>
</div>