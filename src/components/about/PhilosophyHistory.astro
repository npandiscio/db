---
import Container from '../shared/Container.astro';
import Timeline from './Timeline.astro';
import { Image } from 'astro:assets';
import philosophyImage from '../../assets/img/about-page-img-06.jpg';

const timelineEvents = [
  {
    year: "2008",
    title: "Foundation",
    description: "Founded by Marcus Vane in a small garage in Berlin with a vision for modular living.",
    isFirst: true
  },
  {
    year: "2014",
    title: "Urban Expansion",
    description: "Completed the award-winning 'Vertigo Tower', redefining mixed-use vertical spaces."
  },
  {
    year: "2023",
    title: "Sustainability Award",
    description: "Named 'Firm of the Year' for our commitment to carbon-neutral construction techniques."
  }
];
---

<section class="py-24">
  <Container>
    <div class="grid lg:grid-cols-2 gap-20 lg:gap-32 items-start">
      {/* Philosophy Column */}
      <div class="space-y-8">
        <div class="flex items-center gap-4">
          <div class="h-[1px] w-12 bg-primary" />
          <h2 class="text-sm font-bold uppercase tracking-[0.3em] text-primary">Philosophy</h2>
        </div>
        <h3 class="text-3xl font-black leading-tight">Architecture is a silent language, balancing form and spirit.</h3>
        <p class="text-slate-600 dark:text-slate-400 leading-loose">
          At Studio Alpha, we believe that every structure has a responsibility to its environment and its inhabitants. Our approach is rooted in <strong>essentialism</strong>—stripping away the superfluous to reveal the core character of a site.
        </p>
        <p class="text-slate-600 dark:text-slate-400 leading-loose">
          We don't just build walls; we curate light, texture, and movement. Our designs prioritize sustainability not as a feature, but as a foundational principle of modern longevity.
        </p>
        <div class="pt-4">
         <Image
        src={philosophyImage}
            alt="Detail of concrete and wood material interaction showing architectural textures"
       widths={[240, 540, 720, philosophyImage.width]}
  sizes={`(max-width: 360px) 240px, (max-width: 720px) 540px, (max-width: 1600px) 720px, ${philosophyImage.width}px`}
  
      />
        </div>
      </div>

      {/* History Column */}
      <div class="space-y-8 lg:pt-32">
        <div class="flex items-center gap-4">
          <div class="h-[1px] w-12 bg-primary" />
          <h2 class="text-sm font-bold uppercase tracking-[0.3em] text-primary">Our Journey</h2>
        </div>
        <h3 class="text-3xl font-black leading-tight">From a small studio to a global presence.</h3>
        <div class="space-y-10">
          {timelineEvents.map((event) => (
            <Timeline
              year={event.year}
              title={event.title}
              description={event.description}
              isFirst={event.isFirst}
            />
          ))}
        </div>
      </div>
    </div>
  </Container>
</section>