---
import Container from '../shared/Container.astro';
import Icon from '../shared/Icon.astro';
import TeamMember from './TeamMember.astro';
import team1Image from '../../assets/img/about-page-img-01.jpg';
import team2Image from '../../assets/img/about-page-img-02.jpg';
import team3Image from '../../assets/img/about-page-img-03.jpg';
import team4Image from '../../assets/img/about-page-img-04.jpg';

const team = [
  {
    name: "Marcus Vane",
    role: "Principal Architect",
    image: team1Image,
    alt: "Professional portrait of male principal architect with glasses and suit"
  },
  {
    name: "Elena Rossi",
    role: "Lead Interior Designer",
    image: team2Image,
    alt: "Professional portrait of female lead interior designer with modern attire"
  },
  {
    name: "David Chen",
    role: "Structural Director",
    image: team3Image,
    alt: "Professional portrait of male structural engineer in casual professional wear"
  },
  {
    name: "Sarah Jenkins",
    role: "Sustainability Expert",
    image: team4Image,
    alt: "Professional portrait of female sustainability expert with warm smile"
  }
];
---

<section class="py-24 bg-white dark:bg-slate-900/30">
  <Container>
    <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
      <div class="max-w-xl">
        <div class="flex items-center gap-4 mb-4">
          <div class="h-[1px] w-12 bg-primary" />
          <h2 class="text-sm font-bold uppercase tracking-[0.3em] text-primary">The Team</h2>
        </div>
        <h3 class="text-4xl font-black">The Minds Behind Alpha</h3>
      </div>
      <a href={`${import.meta.env.BASE_URL}careers`} class="group flex items-center gap-2 text-primary font-bold text-sm hover:gap-3 transition-all">
        Join Our Team 
        <Icon name="arrow-narrow-right" size={20} class="transition-transform group-hover:translate-x-1" />
      </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {team.map((member) => (
        <TeamMember
          name={member.name}
          role={member.role}
          image={member.image}
          alt={member.alt}
        />
      ))}
    </div>
  </Container>
</section>
