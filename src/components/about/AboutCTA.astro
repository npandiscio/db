---
import Container from '../shared/Container.astro';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<section class="py-24">
  <Container>
    <div class="bg-primary/5 dark:bg-primary/10 rounded-xl p-16 border border-primary/10 text-center">
      <h2 class="text-4xl font-black mb-6">Have a vision for your space?</h2>
      <p class="text-lg text-slate-600 dark:text-slate-400 mb-10 max-w-xl mx-auto">
        Let's discuss how we can bring clarity and purpose to your next project. Our consultations are the first step in a lasting partnership.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={`${base}contact`} class="bg-primary text-white px-10 py-4 rounded font-bold hover:bg-primary/90 transition-all inline-block">
          Start a Project
        </a>
        <a href={`${base}projects`} class="border-2 border-primary text-primary px-10 py-4 rounded font-bold hover:bg-primary/5 transition-all inline-block">
          Our Portfolio
        </a>
      </div>
    </div>
  </Container>
</section>
